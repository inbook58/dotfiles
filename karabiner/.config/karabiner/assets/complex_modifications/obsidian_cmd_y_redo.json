{
  "title": "Obsidian Cmd+Y to Redo",
  "rules": [
    {
      "description": "Map Cmd+Y to Cmd+Shift+Z in Obsidian",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^md\\.obsidian$"
              ]
            }
          ],
          "from": {
            "key_code": "y",
            "modifiers": {
              "mandatory": ["command"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "z",
              "modifiers": ["command", "shift"]
            }
          ]
        }
      ]
    }
  ]
}
